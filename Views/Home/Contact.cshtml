@{
    ViewBag.Title = "Contact Us";
}
@model StudentEnrollment.Models.Contact
<h2>@ViewBag.Title.</h2>
<h3>@ViewBag.Message</h3>

<div class="right-side" style="flex: 3">
    @using (Html.BeginForm("EnquiryForm", "ContactController", FormMethod.Post))
    {
        @* Name *@
        <div class="form-group">
            @Html.LabelFor(model => model.Name)
            @Html.TextBoxFor(model => model.Name, new { @class = "form-control", type = "name", required = "required" })
            @Html.ValidationMessageFor(model => model.Name, "", new { @class = "text-danger" })
        </div>
        @* Phone Number *@
        <div class="form-group">
            @Html.LabelFor(model => model.PhoneNumber)
            @Html.TextBoxFor(model => model.PhoneNumber, new { @class = "form-control", type = "phonenumber", required = "required" })
            @Html.ValidationMessageFor(model => model.PhoneNumber, "", new { @class = "text-danger" })
        </div>
        @* Enquiry Detail *@
        <div class="form-group">
            @Html.LabelFor(model => model.EnquiryDetail)
            @Html.TextBoxFor(model => model.EnquiryDetail, new { @class = "form-control", required = "required" })
            @Html.ValidationMessageFor(model => model.EnquiryDetail, "", new { @class = "text-danger" })
        </div>

        <button type="submit" class="btn btn-primary">Submit</button>
    }
</div>

<address>
    One Microsoft Way<br />
    Redmond, WA 98052-6399<br />
    <abbr title="Phone">P:</abbr>
    425.555.0100
</address>

<address>
    <strong>Support:</strong>   <a href="mailto:Support@example.com">Support@example.com</a><br />
    <strong>Marketing:</strong> <a href="mailto:Marketing@example.com">Marketing@example.com</a>
</address>