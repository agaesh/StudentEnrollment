@model IEnumerable<StudentEnrollment.Models.UserAccount>

@{
    ViewBag.Title = "User Management";
}

<h2>@ViewBag.Title</h2>
<p>
    @Html.ActionLink("Create Admin", "Create", new { isAdmin = true})
    @Html.ActionLink("Create Student", "Create", new { isAdmin = false})
</p>
<table class="table">
    <tr>
        <th>
           FullName 
        </th> 
        <th>
            @Html.DisplayNameFor(model => model.Email)
        </th>
        <th>
            @Html.DisplayNameFor(model => model.Password)
        </th>
        <th>
            @Html.DisplayNameFor(model => model.PhoneNumber)
        </th>
        <th>
            @Html.DisplayNameFor(model => model.RoleType)
        </th>

        <th>
            @Html.DisplayNameFor(Model => Model.IsActive)
        </th>

        <th>
            @Html.DisplayNameFor(model => model.CreatedAt)
        </th>
    </tr>

@foreach (var item in Model) {
<tr class="clickable-row">

    <td>
        @Html.Raw($"{item.FirstName} {item.LastName}")
    </td>

    <td>
        @Html.DisplayFor(model => item.Email)
    </td>
    <td>
        @Html.DisplayFor(model => item.Password)
    </td>

    <td>
        @Html.DisplayFor(model => item.PhoneNumber)
    </td>

    <td>
        @Html.DisplayFor(model => item.RoleType)
    </td>

    <td>
        @Html.DisplayFor(model => item.IsActive)
    </td>

    <td>
        @item.CreatedAt.ToString("dd-MM-yyyy")
    </td>

    <td>
        @Html.ActionLink("Edit", "Edit", new { id = item.ID }) |
        @Html.ActionLink("Details", "Details", new { id = item.ID }) |
        @Html.ActionLink("Delete", "Delete", new { id = item.ID })
    </td>
</tr>
}

</table>
