@{ ViewBag.Title = "Index";}

<div class="container-fluid mt-4">    @if (Session["UserID"] != null)     {           <p>Welcome, @Session["UserEmail"]!</p>           <a href="@Url.Action("Logout", "Account")">Logout</a>    }    <div class="row g-4">        <!-- User Management Card -->        <div class="col-md-4">            <div class="card bg-primary text-white shadow-lg rounded-3">                <div class="card-body text-center p-4">                    <h5 class="card-title fw-bold">User Management</h5>                    <p class="card-text" style="padding:10px; font-weight:bolder; margin-top:20px;">Manage users, roles, and permissions.</p>                    <a href="@Url.Action("Index", "UserManagement")" class="btn btn-light fw-bold">Go to Users</a>                </div>            </div>        </div>        <!-- Course Management Card -->        <div class="col-md-4">            <div class="card bg-success text-white shadow-lg rounded-3">                <div class="card-body text-center p-4">                    <h5 class="card-title" style="padding:10px; font-weight:bolder; margin-top:20px;">Course Management</h5>                    <p class="card-text">Manage courses and scheduling.</p>                    <a href="@Url.Action("Index", "CourseManagement")" class="btn btn-light fw-bold">Go to Courses</a>                </div>            </div>        </div>        <!-- Course Enrollment Card -->        <div class="col-md-4">            <div class="card bg-warning text-dark shadow-lg rounded-3">                <div class="card-body text-center p-4" style="padding:10px; font-weight:bolder; margin-top:20px;">                    <h5 class="card-title fw-bold">Course Enrollment</h5>                    <p class="card-text">Enroll in available courses now.</p>                    <a href="@Url.Action("Index", "CourseEnrollment")" class="btn btn-dark fw-bold">Go to Enrollment</a>                </div>            </div>        </div>    </div></div>