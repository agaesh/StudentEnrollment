@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@model StudentEnrollment.Models.UserAccount

@{ ViewData["Title"] = "Update Bank Details"; }

<h2>Update Bank Details</h2>

<form asp-action="UpdateBankDetails" method="post">
    <div class="form-group">
        <label asp-for="BankName">Bank Name</label>
        <input asp-for="BankName" class="form-control" required />
    </div>

    <div class="form-group">
        <label asp-for="AccountNumber">Account Number</label>
        <input asp-for="AccountNumber" class="form-control" required />
    </div>

    <div class="form-group">
        <label asp-for="AccountType">Account Type</label>
        <select asp-for="AccountType" class="form-control" required>
            <option value="">Select Account Type</option>
            <option value="Savings">Savings</option>
            <option value="Current">Current</option>
            <option value="Business">Business</option>
        </select>
    </div>

    <button type="submit" class="btn btn-primary">Update</button>
</form>


